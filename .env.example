# Copier ce fichier vers .env et remplir les valeurs.
# Le fichier .env ne doit pas être commité (déjà dans .gitignore).

DB_HOST=localhost
DB_NAME=expertise
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_PORT=3306

# Clé secrète pour l’encodage des IDs dans les URLs publiques (paramètre h). Générer une chaîne aléatoire longue (ex. 32 caractères).
# APP_URL_SECRET=votre-cle-secrete-longue-et-aleatoire

# Chemin web de base pour les liens (navbar, footer, assets, admin).
# - Production (site à la racine, ex. https://www.expertisehs.org/) : SITE_BASE_URL=/ ou laisser vide
# - Local sous-dossier (ex. http://localhost/expertise/) : SITE_BASE_URL=/expertise/
# Si non défini, le code utilise /expertise/ par défaut.
# SITE_BASE_URL=
